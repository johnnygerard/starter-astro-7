---
import Layout from "~/layouts/Layout.astro";
---

<Layout
  title="Astro 7 Starter"
  description="Minimal Astro 7 starter template preconfigured for deployment on Cloudflare Workers."
>
  <main
    class="mx-auto flex min-h-svh max-w-2xl flex-col items-start justify-center gap-4 bg-white px-6 py-16 text-gray-900 antialiased"
  >
    <h1 class="text-4xl font-bold tracking-tight">Homepage</h1>
    <a
      class="text-blue-600 underline underline-offset-4 hover:text-blue-800"
      href="/not-found"
    >
      Test 404 page
    </a>
  </main>
</Layout>
