---
import Layout from "~/layouts/Layout.astro";
---

<Layout
  title="404 – Page Not Found"
  description="Error page for the 404 HTTP status code"
  noIndex
>
  <main
    class="mx-auto flex min-h-svh max-w-2xl flex-col items-start justify-center gap-4 bg-white px-6 py-16 text-gray-900 antialiased"
  >
    <hgroup class="flex flex-col gap-1">
      <p class="text-sm font-medium text-gray-500">404 Error</p>
      <h1 class="text-4xl font-bold tracking-tight">Page Not Found</h1>
    </hgroup>
    <p class="text-gray-600">
      Sorry, the page you are looking for does not exist or has been moved.
    </p>
    <a
      class="text-blue-600 underline underline-offset-4 hover:text-blue-800"
      href="/"
    >
      Back to Home
    </a>
  </main>
</Layout>
