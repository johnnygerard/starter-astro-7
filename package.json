{
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "astro": "^6.4.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.99.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "onFail": "warn",
      "version": "11"
    },
    "runtime": {
      "name": "node",
      "onFail": "warn",
      "version": "24"
    }
  },
  "name": "starter-astro-7",
  "private": true,
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "check": "astro check",
    "deploy": "npm run build && wrangler deploy --outdir dist",
    "deploy:check": "wrangler deploy --outdir dist --dry-run",
    "dev": "astro dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "astro preview --port 3321",
    "pw": "playwright",
    "pw:test": "playwright test",
    "qa": "npm run format:check && npm run build && npm run check && npm test && npm run pw:test",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "wg": "wrangler"
  },
  "type": "module",
  "version": "0.0.0"
}
